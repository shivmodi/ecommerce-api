APP_NAME=ConverzAI E-Commerce API
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=ecommerce
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_INDEX=products

DUMMY_PRODUCTS_URL=https://dummyjson.com/products?limit=200